rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/membres/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() { return hasRole('admin'); }
    function isMembre() { return hasRole('membre') || isAdmin(); }
    function isOwner(uid) { return request.auth.uid == uid; }

    // Livres : lecture ouverte, écriture admin
    match /livres/{livreId} {
      allow read: if true;
      allow write: if isAdmin();

      match /avis/{avisId} {
        allow read: if true;
        allow create: if isMembre();
        allow update, delete: if isOwner(resource.data.membreId) || isAdmin();
      }
    }

    // Membres : lecture auth, écriture propriétaire ou admin
    match /membres/{membreId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(membreId);
      allow update: if isOwner(membreId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Emprunts : membre concerné ou admin
    match /emprunts/{empruntId} {
      allow read: if isAuthenticated() &&
        (resource.data.membreId == request.auth.uid || isAdmin());
      allow create: if isMembre();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow read: if isAuthenticated() &&
        (resource.data.membreId == request.auth.uid || isAdmin());
      allow create: if isMembre();
      allow update, delete: if isOwner(resource.data.membreId) || isAdmin();
    }

    // Événements
    match /evenements/{evenementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Conversations et messages
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated() &&
        request.auth.uid in resource.data.participantsIds;
      allow create: if isAuthenticated();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }
  }
}
